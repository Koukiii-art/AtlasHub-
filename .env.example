APP_NAME=AtlasHub
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app-name.up.railway.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Railway PostgreSQL (set these in Railway dashboard via service variables)
# Railway automatically provides PGHOST, PGPORT, PGDATABASE, PGUSER, PGPASSWORD
DB_CONNECTION=pgsql
DB_HOST=${PGHOST:-localhost}
DB_PORT=${PGPORT:-5432}
DB_DATABASE=${PGDATABASE:-railway}
DB_USERNAME=${PGUSER:-postgres}
DB_PASSWORD=${PGPASSWORD:-}
DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids

CACHE_STORE=database

# Redis (optional - only if you add a Redis service on Railway)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@atlashub.app"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# OAuth - set these in Railway variables
# Google OAuth - callback URL must be: https://your-app.up.railway.app/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/api/auth/google/callback

# GitHub OAuth - callback URL must be: https://your-app.up.railway.app/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=${APP_URL}/api/auth/github/callback

# Frontend URL (your Vercel frontend)
FRONTEND_URL=https://your-frontend.vercel.app

# Sanctum stateful domains (comma-separated)
SANCTUM_STATEFUL_DOMAINS=your-frontend.vercel.app,localhost,localhost:3000
